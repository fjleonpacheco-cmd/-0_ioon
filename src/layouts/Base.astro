---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'ioon — Estudio de diseño', description = 'Diseño de Autor + Ejecución Automatizada. Estudio de diseño en Oaxaca, México.' } = Astro.props;
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body class="min-h-screen">
  <slot />
</body>
</html>
