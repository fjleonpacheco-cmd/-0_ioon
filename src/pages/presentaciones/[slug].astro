---
import Base from '../../layouts/Base.astro';
import fs from 'node:fs';
import path from 'node:path';

export function getStaticPaths() {
  const presDir = path.resolve('src/content/presentaciones');
  if (!fs.existsSync(presDir)) return [];
  const slugs = fs.readdirSync(presDir).filter(f => {
    const full = path.join(presDir, f);
    return fs.statSync(full).isDirectory() && fs.existsSync(path.join(full, 'config.json'));
  });
  return slugs.map(slug => {
    const config = JSON.parse(fs.readFileSync(path.join(presDir, slug, 'config.json'), 'utf-8'));
    return { params: { slug }, props: { config, slug } };
  });
}

const { config, slug } = Astro.props;
const { title, client, date, password, slides, sections, layout } = config;
const hasPassword = !!password;
const isSections = layout === 'sections' && sections;

function imgSrc(s: string) {
  return s.startsWith('http') ? s : `/presentaciones/${slug}/${s}`;
}
---
<Base title={`${title} — ioon`} description={`Presentación para ${client || 'cliente'}`}>

  {hasPassword && (
    <div id="pw-gate" class="fixed inset-0 z-50 bg-[--color-paper] flex items-center justify-center">
      <div class="text-center stagger">
        <p class="text-xs tracking-[0.3em] uppercase text-[--color-muted] mb-6">Acceso protegido</p>
        <h2 class="text-2xl font-light mb-8">{title}</h2>
        <div class="flex gap-3">
          <input type="password" id="pw-input" class="pw-input w-48" placeholder="Contraseña" autocomplete="off" />
          <button id="pw-btn" class="px-5 py-3 bg-[--color-ink] text-[--color-paper] text-sm tracking-[0.1em] uppercase hover:opacity-80 transition-opacity cursor-pointer">Entrar</button>
        </div>
        <p id="pw-error" class="mt-4 text-xs text-red-500 hidden">Contraseña incorrecta</p>
      </div>
    </div>
  )}

  <div id="deck" class={hasPassword ? 'hidden' : ''}>

  {isSections ? (
    <div>
    <style>{`
      /* ── ioon directrices overrides ── */
      .ioon-progress { position:fixed;top:0;left:0;height:2px;background:var(--color-ink);transition:width 0.3s ease;z-index:100; }
      .ioon-sec-label { position:fixed;top:16px;left:80px;font-size:11px;font-weight:400;letter-spacing:2px;text-transform:uppercase;color:var(--color-muted);z-index:90; }
      @media(max-width:768px){ .ioon-sec-label { left:24px; } }
      #sec-nav { position:fixed!important;left:20px!important;right:auto!important;top:50%!important;transform:translateY(-50%)!important;gap:6px!important;z-index:90!important; }
      @media(max-width:768px){ #sec-nav { left:8px!important; } }
      .sec-dot { padding:0!important;gap:0!important; }
      .sec-dot .dot-circle { width:8px!important;height:8px!important;border-radius:50%;border:1.5px solid var(--color-muted)!important;background:transparent;transition:all 0.25s;display:block; }
      .sec-dot .dot-circle.active { background:var(--color-ink)!important;border-color:var(--color-ink)!important; }
      .sec-dot .dot-label { position:absolute;left:16px;top:50%;transform:translateY(-50%);font-size:10px;text-transform:uppercase;letter-spacing:1px;color:var(--color-muted);white-space:nowrap;opacity:0;pointer-events:none;transition:opacity 0.2s; }
      .sec-dot:hover .dot-label { opacity:1; }
      @media(max-width:768px){ .sec-dot .dot-label { display:none; } }
      .ioon-nav-arrows { position:fixed;bottom:12px;left:50%;transform:translateX(-50%);display:flex;gap:24px;z-index:90;font-family:var(--font-sans); }
      .ioon-nav-arrows button { font-size:14px;color:var(--color-muted);cursor:pointer;background:none;border:none;font-family:inherit;transition:color 0.2s;padding:4px;line-height:1; }
      .ioon-nav-arrows button:hover { color:var(--color-ink); }
      .ioon-hdots { position:fixed!important;bottom:40px;left:50%;transform:translateX(-50%);display:flex;gap:6px;z-index:90; }
      .ioon-hdots .hdot { width:7px!important;height:7px!important;border-radius:50%!important;border:1.5px solid var(--color-muted);transition:all 0.25s;cursor:pointer;padding:0!important; }
      .ioon-version { position:fixed;bottom:12px;right:20px;font-size:9px;font-weight:400;letter-spacing:1px;text-transform:uppercase;color:var(--color-highlight);z-index:90; }
      .vsection { min-height:100vh!important;height:100vh;overflow:hidden; }
      .hslide { height:100vh;display:flex!important;align-items:center;justify-content:center; }
      .hslide.hidden { display:none!important; }
      .slide-enter { max-width:900px;width:100%; }
      @keyframes fadeIn { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:translateY(0)} }
      .slide-enter { animation:fadeIn 0.35s ease both; }
      .l3-content { animation:fadeIn 0.25s ease both; }
      /* heading sizes per directrices */
      .ioon-h1 { font-size:clamp(32px,5vw,56px)!important;font-weight:300!important;letter-spacing:-1px!important;line-height:1.15!important; }
      .ioon-h2 { font-size:clamp(22px,3vw,34px)!important;font-weight:300!important;letter-spacing:-0.5px!important;line-height:1.3!important; }
      .ioon-h3 { font-size:clamp(18px,2.2vw,26px)!important;font-weight:300!important;letter-spacing:-0.5px!important;line-height:1.4!important; }
      .ioon-concept-h { font-size:clamp(32px,5vw,56px)!important;font-weight:300!important;letter-spacing:-1px!important;line-height:1.15!important; }
      .ioon-concept-sub { font-size:clamp(22px,3vw,34px)!important;font-weight:300!important;letter-spacing:-0.5px!important;color:var(--color-muted)!important;margin-top:12px!important; }
      .ioon-body { font-size:16px!important;font-weight:300!important;line-height:1.7!important;color:var(--color-accent)!important;max-width:680px; }
      .ioon-overline { font-size:13px;font-weight:400;letter-spacing:3px;text-transform:uppercase;color:var(--color-muted);margin-bottom:16px; }
      .ioon-subheading { font-size:16px;font-weight:300;color:var(--color-muted);margin-top:12px; }
      .l3-btn { font-size:13px!important;font-weight:400!important;letter-spacing:normal!important;text-transform:none!important;padding:8px 16px!important; }
      @media(max-width:768px){ .l3-btn { font-size:11px!important;padding:6px 10px!important; } }
      #sec-counter { display:none; }
    `}</style>

    <div class="ioon-progress" id="progress-bar" style="width:0%"></div>
    <div class="ioon-sec-label" id="sec-label"></div>
    <div class="ioon-version">Propuesta C1 — v20260414</div>

    <div class="fixed left-5 md:left-5 top-1/2 -translate-y-1/2 z-40 flex flex-col gap-1.5" id="sec-nav">
      {sections.map((sec: any, i: number) => (
        <button class="sec-dot relative cursor-pointer transition-all" data-sec={i}>
          <span class={`dot-circle ${i === 0 ? 'active' : ''}`} />
          <span class="dot-label">{sec.title}</span>
        </button>
      ))}
    </div>

    <div id="sec-counter" style="display:none">1/{sections.length}</div>

    <main>
      {sections.map((sec: any, si: number) => (
        <section class="vsection flex flex-col" data-section={si} style={si > 0 ? 'display:none' : ''}>
          <div class="flex-1 flex items-center overflow-hidden">
            <div class="hslides-wrap w-full" data-section={si}>
              {sec.slides.map((slide: any, hi: number) => (
                <div class={`hslide w-full px-12 md:px-20 py-8 ${hi > 0 ? 'hidden' : ''}`} data-hindex={hi}>
                  <div class="max-w-4xl mx-auto slide-enter">

                    {slide.type === 'title' && (
                      <div class="text-center py-12">
                        {slide.overline && <p class="text-xs tracking-[0.3em] uppercase text-[--color-muted] mb-6">{slide.overline}</p>}
                        {slide.heading && <h1 class="text-[clamp(2rem,5vw,5rem)] font-light leading-[0.95] tracking-tight">{slide.heading}</h1>}
                        {slide.headingHtml && <h1 class="text-[clamp(2rem,5vw,5rem)] font-light leading-[0.95] tracking-tight" set:html={slide.headingHtml} />}
                        {slide.subheading && <p class="mt-6 text-lg text-[--color-muted] font-light">{slide.subheading}</p>}
                        {slide.subheadingHtml && <p class="mt-6 text-lg text-[--color-muted] font-light" set:html={slide.subheadingHtml} />}
                      </div>
                    )}

                    {slide.type === 'text' && !slide.l3 && (
                      <div>
                        {slide.heading && <h3 class="text-2xl md:text-3xl font-light mb-6">{slide.heading}</h3>}
                        {slide.headingHtml && <h3 class="text-2xl md:text-3xl font-light mb-6" set:html={slide.headingHtml} />}
                        {slide.body && <p class="text-base md:text-lg text-[--color-muted] leading-relaxed max-w-2xl">{slide.body}</p>}
                        {slide.bodyHtml && <p class="text-base md:text-lg text-[--color-muted] leading-relaxed max-w-2xl" set:html={slide.bodyHtml} />}
                        {slide.bullets && !slide.bulletsHtml && (<ul class="mt-6 space-y-3 list-disc pl-5 marker:text-[--color-ink]">{slide.bullets.map((b: string) => (<li class="text-base text-[--color-muted] pl-1">{b}</li>))}</ul>)}
                        {slide.bulletsHtml && (<ul class="mt-6 space-y-3 list-disc pl-5 marker:text-[--color-ink]">{slide.bulletsHtml.map((b: string) => (<li class="text-base text-[--color-muted] pl-1" set:html={b} />))}</ul>)}
                        {slide.imgLayout && slide.images && (
                          <div class={`mt-8 ${slide.imgLayout === '2x' ? 'grid grid-cols-2 gap-4' : slide.imgLayout === '1of2' ? 'grid grid-cols-2 gap-4' : slide.imgLayout === '4p' ? 'grid grid-cols-2 md:grid-cols-4 gap-4' : ''}`}>
                            {slide.images.map((img: string) => (
                              <img src={imgSrc(img)} alt="" class={`w-full object-cover rounded-sm ${slide.imgLayout === 'a' ? 'aspect-[4/3]' : slide.imgLayout === '2x' ? 'aspect-[4/3]' : slide.imgLayout === '1of2' ? 'aspect-[4/3]' : slide.imgLayout === '4p' ? 'aspect-[3/4]' : 'aspect-video'}`} loading="lazy" />
                            ))}
                          </div>
                        )}
                      </div>
                    )}

                    {slide.type === 'text' && slide.l3 && (
                      <div>
                        {slide.heading && <h3 class="text-2xl md:text-3xl font-light mb-4">{slide.heading}</h3>}
                        {slide.headingHtml && <h3 class="text-2xl md:text-3xl font-light mb-4" set:html={slide.headingHtml} />}
                        {slide.body && <p class="text-base md:text-lg text-[--color-muted] leading-relaxed max-w-2xl mb-2">{slide.body}</p>}
                        {slide.bodyHtml && <p class="text-base md:text-lg text-[--color-muted] leading-relaxed max-w-2xl mb-2" set:html={slide.bodyHtml} />}
                        <div class="flex gap-0 border-b border-[--color-border] mt-4 mb-4 l3-tabs" data-l3={`${si}-${hi}`}>
                          {slide.l3.map((tab: any, ti: number) => (
                            <button
                              class={`l3-btn px-4 py-2 text-xs tracking-[0.08em] uppercase border-b-2 transition-all cursor-pointer ${ti === 0 ? 'text-[--color-ink] border-[--color-ink]' : 'text-[--color-muted] border-transparent hover:text-[--color-ink]'}`}
                              data-l3={`${si}-${hi}`}
                              data-ti={ti}
                            >{tab.label}</button>
                          ))}
                        </div>
                        {slide.l3.map((tab: any, ti: number) => (
                          <div class={`l3-content ${ti === 0 ? '' : 'hidden'}`} data-l3c={`${si}-${hi}-${ti}`}>
                            {tab.heading && <h4 class="text-xl md:text-2xl font-light mb-4">{tab.heading}</h4>}
                            {tab.headingHtml && <h4 class="text-xl md:text-2xl font-light mb-4" set:html={tab.headingHtml} />}
                            {tab.body && <p class="text-base text-[--color-muted] leading-relaxed max-w-2xl">{tab.body}</p>}
                            {tab.bodyHtml && <p class="text-base text-[--color-muted] leading-relaxed max-w-2xl" set:html={tab.bodyHtml} />}
                            {tab.bullets && (<ul class="mt-4 space-y-2 list-disc pl-5 marker:text-[--color-ink]">{tab.bullets.map((b: string) => (<li class="text-sm text-[--color-muted] pl-1">{b}</li>))}</ul>)}
                            {tab.imgLayout && tab.images && (
                              <div class={`mt-6 ${tab.imgLayout === '2x' ? 'grid grid-cols-2 gap-4' : tab.imgLayout === '1of2' ? 'grid grid-cols-2 gap-4' : tab.imgLayout === '4p' ? 'grid grid-cols-2 md:grid-cols-4 gap-4' : ''}`}>
                                {tab.images.map((img: string) => (
                                  <img src={imgSrc(img)} alt="" class={`w-full object-cover rounded-sm ${tab.imgLayout === 'a' ? 'aspect-[4/3]' : tab.imgLayout === '2x' ? 'aspect-[4/3]' : tab.imgLayout === '1of2' ? 'aspect-[4/3]' : tab.imgLayout === '4p' ? 'aspect-[3/4]' : 'aspect-video'}`} loading="lazy" />
                                ))}
                              </div>
                            )}
                          </div>
                        ))}
                      </div>
                    )}

                    {slide.type === 'image' && (
                      <div>
                        <img src={imgSrc(slide.src)} alt={slide.alt || ''} class="w-full max-h-[60vh] object-contain" />
                        {slide.caption && <p class="mt-4 text-xs text-[--color-muted] text-center">{slide.caption}</p>}
                      </div>
                    )}

                    {slide.type === 'split' && (
                      <div class="grid md:grid-cols-2 gap-12 items-center">
                        <img src={imgSrc(slide.src)} alt={slide.alt || ''} class="w-full object-cover max-h-[55vh]" />
                        <div>
                          {slide.heading && <h3 class="text-2xl font-light mb-4">{slide.heading}</h3>}
                          {slide.body && <p class="text-base text-[--color-muted] leading-relaxed">{slide.body}</p>}
                          {slide.bodyHtml && <p class="text-base text-[--color-muted] leading-relaxed" set:html={slide.bodyHtml} />}
                        </div>
                      </div>
                    )}

                    {slide.type === 'quote' && (
                      <div class="text-center max-w-2xl mx-auto py-12">
                        {slide.text && <blockquote class="text-2xl md:text-3xl font-light leading-relaxed italic">&ldquo;{slide.text}&rdquo;</blockquote>}
                        {slide.textHtml && <blockquote class="text-2xl md:text-3xl font-light leading-relaxed italic" set:html={`&ldquo;${slide.textHtml}&rdquo;`} />}
                        {slide.attribution && <p class="mt-6 text-sm text-[--color-muted]">— {slide.attribution}</p>}
                      </div>
                    )}

                    {slide.type === 'concept' && (
                      <div>
                        {slide.heading && <h2 class="text-[clamp(1.6rem,4vw,3rem)] font-light leading-[1.15] tracking-tight">{slide.heading}</h2>}
                        {slide.headingHtml && <h2 class="text-[clamp(1.6rem,4vw,3rem)] font-light leading-[1.15] tracking-tight" set:html={slide.headingHtml} />}
                        {slide.subheading && <p class="text-xl md:text-2xl font-light text-[--color-muted] mt-3">{slide.subheading}</p>}
                        {slide.body && <p class="text-base md:text-lg text-[--color-muted] leading-relaxed max-w-2xl mt-4">{slide.body}</p>}
                        {slide.bodyHtml && <div class="text-base md:text-lg text-[--color-muted] leading-relaxed max-w-2xl mt-4" set:html={slide.bodyHtml} />}
                      </div>
                    )}

                  </div>
                </div>
              ))}
            </div>
          </div>

          {sec.slides.length > 1 && (
            <div class="ioon-hdots hdots" data-section={si}>
              {sec.slides.map((_: any, hi: number) => (
                <button class={`hdot transition-all cursor-pointer`} data-hi={hi} style={hi === 0 ? 'background:var(--color-ink);border-color:var(--color-ink)' : 'background:transparent'} />
              ))}
            </div>
          )}
        </section>
      ))}
    </main>

    <div class="ioon-nav-arrows">
      <button class="varrow-up" title="Sección anterior">↑</button>
      <button class="harrow-left" title="Anterior">←</button>
      <button class="harrow-right" title="Siguiente">→</button>
      <button class="varrow-down" title="Sección siguiente">↓</button>
    </div>

    </div>
  ) : (
    <div>
    <nav class="fixed top-0 left-0 w-full z-40 bg-[--color-paper]/90 backdrop-blur-sm border-b border-[--color-border]">
      <div class="flex items-center justify-between px-6 md:px-12 py-4">
        <a href="/" class="hover:opacity-70 transition-opacity"><img src="/logo.png" alt="ioon" class="h-6" /></a>
        <div class="text-center">
          <span class="text-sm font-medium block">{title}</span>
          {client && <span class="text-xs text-[--color-muted] block">{client}</span>}
        </div>
        <div class="text-xs text-[--color-muted]"><span id="current-slide">1</span>/<span id="total-slides">{slides.length}</span></div>
      </div>
      <div class="h-px bg-[--color-border] relative"><div id="progress" class="h-px bg-[--color-ink] transition-all duration-300" style="width: 0%"></div></div>
    </nav>
    <main class="pt-16">
      {slides.map((slide: any, i: number) => (
        <section class="slide min-h-screen flex items-center justify-center px-6 md:px-12 py-20" data-index={i} style={i > 0 ? 'display:none' : ''}>
          <div class="max-w-4xl w-full slide-enter">
            {slide.type === 'title' && (<div class="text-center">{slide.overline && <p class="text-xs tracking-[0.3em] uppercase text-[--color-muted] mb-6">{slide.overline}</p>}<h1 class="text-[clamp(2rem,5vw,5rem)] font-light leading-[0.95] tracking-tight">{slide.heading}</h1>{slide.subheading && <p class="mt-6 text-lg text-[--color-muted] font-light">{slide.subheading}</p>}</div>)}
            {slide.type === 'text' && (<div>{slide.heading && <h2 class="text-3xl md:text-4xl font-light mb-8">{slide.heading}</h2>}{slide.body && <p class="text-base md:text-lg text-[--color-muted] leading-relaxed max-w-2xl">{slide.body}</p>}{slide.bullets && (<ul class="mt-6 space-y-3 list-disc pl-5 marker:text-[--color-ink]">{slide.bullets.map((b: string) => (<li class="text-base text-[--color-muted] pl-1">{b}</li>))}</ul>)}</div>)}
            {slide.type === 'image' && (<div><img src={imgSrc(slide.src)} alt={slide.alt || ''} class="w-full max-h-[70vh] object-contain" />{slide.caption && <p class="mt-4 text-xs text-[--color-muted] text-center">{slide.caption}</p>}</div>)}
            {slide.type === 'split' && (<div class="grid md:grid-cols-2 gap-12 items-center"><img src={imgSrc(slide.src)} alt={slide.alt || ''} class="w-full object-cover" /><div>{slide.heading && <h2 class="text-2xl font-light mb-4">{slide.heading}</h2>}{slide.body && <p class="text-base text-[--color-muted] leading-relaxed">{slide.body}</p>}</div></div>)}
            {slide.type === 'quote' && (<div class="text-center max-w-2xl mx-auto"><blockquote class="text-2xl md:text-3xl font-light leading-relaxed italic">&ldquo;{slide.text}&rdquo;</blockquote>{slide.attribution && <p class="mt-6 text-sm text-[--color-muted]">— {slide.attribution}</p>}</div>)}
            {slide.type === 'concept' && (<div>{slide.heading && <h2 class="text-[clamp(1.6rem,4vw,3rem)] font-light leading-[1.15] tracking-tight">{slide.heading}</h2>}{slide.headingHtml && <h2 class="text-[clamp(1.6rem,4vw,3rem)] font-light leading-[1.15] tracking-tight" set:html={slide.headingHtml} />}{slide.subheading && <p class="text-xl md:text-2xl font-light text-[--color-muted] mt-3">{slide.subheading}</p>}{slide.body && <p class="text-base md:text-lg text-[--color-muted] leading-relaxed max-w-2xl mt-4">{slide.body}</p>}{slide.bodyHtml && <div class="text-base md:text-lg text-[--color-muted] leading-relaxed max-w-2xl mt-4" set:html={slide.bodyHtml} />}</div>)}
          </div>
        </section>
      ))}
    </main>
    <div class="fixed bottom-8 left-1/2 -translate-x-1/2 z-40 flex gap-1">
      <button id="prev" class="p-3 text-[--color-muted] hover:text-[--color-ink] transition-colors cursor-pointer"><svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 4L6 10L12 16"/></svg></button>
      <button id="next" class="p-3 text-[--color-muted] hover:text-[--color-ink] transition-colors cursor-pointer"><svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 4L14 10L8 16"/></svg></button>
    </div>
    </div>
  )}

  </div>

  <script define:vars={{ hasPassword, password: password || '', isSections, configJSON: JSON.stringify(config) }}>
    if (hasPassword) {
      var gate = document.getElementById('pw-gate'), deck = document.getElementById('deck');
      var input = document.getElementById('pw-input'), btn = document.getElementById('pw-btn'), err = document.getElementById('pw-error');
      function tryUnlock() { if (input.value === password) { gate.classList.add('hidden'); deck.classList.remove('hidden'); } else { err.classList.remove('hidden'); input.value = ''; input.focus(); } }
      btn.addEventListener('click', tryUnlock);
      input.addEventListener('keydown', function(e) { if (e.key === 'Enter') tryUnlock(); });
    }

    if (isSections) {
      var cfg = JSON.parse(configJSON);
      var curSec = 0, curH = [];
      var vsections = document.querySelectorAll('.vsection');
      var secDots = document.querySelectorAll('.sec-dot');
      var secCounter = document.getElementById('sec-counter');
      var secLabel = document.getElementById('sec-label');
      var progressBar = document.getElementById('progress-bar');
      var curL3 = {};
      vsections.forEach(function() { curH.push(0); });

      function updateDots() {
        secDots.forEach(function(d, i) {
          var circle = d.querySelector('.dot-circle');
          if (i === curSec) { circle.style.background = 'var(--color-ink)'; circle.style.borderColor = 'var(--color-ink)'; }
          else { circle.style.background = 'transparent'; circle.style.borderColor = 'var(--color-muted)'; }
        });
        if (secCounter) secCounter.textContent = (curSec + 1) + '/' + vsections.length;
        if (secLabel) secLabel.textContent = cfg.sections[curSec].title;
        updateProgress();
      }

      function updateProgress() {
        var total = 0, current = 0;
        for (var s = 0; s < cfg.sections.length; s++) {
          for (var sl = 0; sl < cfg.sections[s].slides.length; sl++) {
            var l3c = (cfg.sections[s].slides[sl].l3 && cfg.sections[s].slides[sl].l3.length) || 1;
            if (s < curSec || (s === curSec && sl < curH[curSec])) current += l3c;
            else if (s === curSec && sl === curH[curSec]) { var key = s + '-' + sl; current += (curL3[key] || 0); }
            total += l3c;
          }
        }
        if (progressBar) progressBar.style.width = (total > 0 ? ((current + 1) / total) * 100 : 0) + '%';
      }

      function showSection(si) {
        vsections[curSec].style.display = 'none'; curSec = si; vsections[curSec].style.display = '';
        updateDots(); showHSlide(curSec, curH[curSec]);
      }

      function showHSlide(si, hi) {
        var wrap = document.querySelector('.hslides-wrap[data-section="' + si + '"]');
        var hs = wrap.querySelectorAll('.hslide');
        var dotsWrap = document.querySelector('.hdots[data-section="' + si + '"]');
        hs.forEach(function(s, i) {
          if (i === hi) { s.classList.remove('hidden'); var inner = s.querySelector('.slide-enter'); if (inner) { inner.style.animation = 'none'; inner.offsetHeight; inner.style.animation = ''; } }
          else { s.classList.add('hidden'); }
        });
        if (dotsWrap) { dotsWrap.querySelectorAll('.hdot').forEach(function(d, i) { if (i === hi) { d.style.background = 'var(--color-ink)'; d.style.borderColor = 'var(--color-ink)'; } else { d.style.background = 'transparent'; d.style.borderColor = 'var(--color-muted)'; } }); }
        curH[si] = hi;
      }

      function switchL3(si, hi, ti) {
        var key = si + '-' + hi;
        curL3[key] = ti;
        var btns = document.querySelectorAll('.l3-btn[data-l3="' + key + '"]');
        btns.forEach(function(b, i) {
          if (i === ti) { b.classList.add('text-[--color-ink]'); b.classList.remove('text-[--color-muted]'); b.style.borderBottomColor = 'var(--color-ink)'; }
          else { b.classList.remove('text-[--color-ink]'); b.classList.add('text-[--color-muted]'); b.style.borderBottomColor = 'transparent'; }
        });
        var secs = cfg.sections;
        var l3len = secs[si].slides[hi].l3 ? secs[si].slides[hi].l3.length : 0;
        for (var i = 0; i < l3len; i++) {
          var el = document.querySelector('[data-l3c="' + si + '-' + hi + '-' + i + '"]');
          if (el) { if (i === ti) el.classList.remove('hidden'); else el.classList.add('hidden'); }
        }
      }

      function goUp() { if (curSec > 0) showSection(curSec - 1); }
      function goDown() { if (curSec < vsections.length - 1) showSection(curSec + 1); }
      function goLeft() {
        var secs = cfg.sections;
        var sl = secs[curSec].slides[curH[curSec]];
        if (sl && sl.l3) { var key = curSec + '-' + curH[curSec]; var ci = curL3[key] || 0; if (ci > 0) { switchL3(curSec, curH[curSec], ci - 1); return; } }
        if (curH[curSec] > 0) showHSlide(curSec, curH[curSec] - 1);
      }
      function goRight() {
        var secs = cfg.sections;
        var sl = secs[curSec].slides[curH[curSec]];
        if (sl && sl.l3) { var key = curSec + '-' + curH[curSec]; var ci = curL3[key] || 0; if (ci < sl.l3.length - 1) { switchL3(curSec, curH[curSec], ci + 1); return; } }
        var wrap = document.querySelector('.hslides-wrap[data-section="' + curSec + '"]'); var t = wrap.querySelectorAll('.hslide').length;
        if (curH[curSec] < t - 1) showHSlide(curSec, curH[curSec] + 1);
      }

      secDots.forEach(function(d) { d.addEventListener('click', function() { showSection(Number(d.dataset.sec)); }); });
      document.querySelectorAll('.hdot').forEach(function(d) { d.addEventListener('click', function() { showHSlide(curSec, Number(d.dataset.hi)); }); });
      document.querySelectorAll('.harrow-left').forEach(function(b) { b.addEventListener('click', goLeft); });
      document.querySelectorAll('.harrow-right').forEach(function(b) { b.addEventListener('click', goRight); });
      document.querySelectorAll('.varrow-up').forEach(function(b) { b.addEventListener('click', goUp); });
      document.querySelectorAll('.varrow-down').forEach(function(b) { b.addEventListener('click', goDown); });
      document.querySelectorAll('.l3-btn').forEach(function(b) {
        b.addEventListener('click', function() { var p = b.dataset.l3.split('-'); switchL3(Number(p[0]), Number(p[1]), Number(b.dataset.ti)); });
      });

      document.addEventListener('keydown', function(e) {
        if (e.key === 'ArrowUp') { e.preventDefault(); goUp(); }
        if (e.key === 'ArrowDown') { e.preventDefault(); goDown(); }
        if (e.key === 'ArrowLeft') { e.preventDefault(); goLeft(); }
        if (e.key === 'ArrowRight' || e.key === ' ') { e.preventDefault(); goRight(); }
      });
      var tx = 0, ty = 0;
      document.addEventListener('touchstart', function(e) { tx = e.touches[0].clientX; ty = e.touches[0].clientY; });
      document.addEventListener('touchend', function(e) {
        var dx = tx - e.changedTouches[0].clientX, dy = ty - e.changedTouches[0].clientY;
        if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 50) { dx > 0 ? goRight() : goLeft(); }
        else if (Math.abs(dy) > 50) { dy > 0 ? goDown() : goUp(); }
      });
      updateDots();
    } else {
      var current = 0, slides2 = document.querySelectorAll('.slide'), total = slides2.length;
      var counter = document.getElementById('current-slide'), progress = document.getElementById('progress');
      function goTo(n) { if (n < 0 || n >= total) return; slides2[current].style.display = 'none'; current = n; var s = slides2[current]; s.style.display = ''; var inner = s.querySelector('.slide-enter'); if (inner) { inner.style.animation = 'none'; inner.offsetHeight; inner.style.animation = ''; } counter.textContent = current + 1; progress.style.width = ((current + 1) / total * 100) + '%'; }
      document.getElementById('prev').addEventListener('click', function() { goTo(current - 1); });
      document.getElementById('next').addEventListener('click', function() { goTo(current + 1); });
      document.addEventListener('keydown', function(e) { if (e.key === 'ArrowRight' || e.key === 'ArrowDown' || e.key === ' ') { e.preventDefault(); goTo(current + 1); } if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') { e.preventDefault(); goTo(current - 1); } });
      var touchStart = 0;
      document.addEventListener('touchstart', function(e) { touchStart = e.touches[0].clientX; });
      document.addEventListener('touchend', function(e) { var diff = touchStart - e.changedTouches[0].clientX; if (Math.abs(diff) > 50) diff > 0 ? goTo(current + 1) : goTo(current - 1); });
      progress.style.width = (1 / total * 100) + '%';
    }
  </script>
