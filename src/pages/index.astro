---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

// Get presentation count for the nav hint
const decks = import.meta.glob('../content/presentaciones/*/config.json', { eager: true });
const deckCount = Object.keys(decks).length;
---
<Base>
  <!-- Nav -->
  <nav class="fixed top-0 left-0 w-full z-50 bg-[--color-paper]/90 backdrop-blur-sm">
    <div class="flex items-center justify-between px-6 md:px-12 py-5">
      <a href="/"><img src="/logo.png" alt="ioon" class="h-7" /></a>
      <a href="#contacto" class="text-[--color-muted] text-xs tracking-[0.2em] uppercase hover:text-[--color-ink] transition-colors">Contacto</a>
    </div>
  </nav>

  <!-- Hero -->
  <section class="h-screen flex flex-col justify-end px-6 md:px-12 pb-24 md:pb-32 relative overflow-hidden">
    <!-- P5.js organic particles -->
    <canvas id="sketch-bg" class="absolute inset-0 z-0" style="width:100%;height:100%;"></canvas>

    <div class="stagger relative z-10">
      <img src="/logo.png" alt="ioon" class="w-[200px] mb-10" />
      <p class="text-[--color-muted] text-xs tracking-[0.3em] uppercase mb-4">Estudio de innovación — Oaxaca, México</p>
      <h1 class="text-[clamp(2rem,5vw,4.5rem)] font-light leading-[0.95] tracking-tight max-w-[30ch]">
        Diseño limpio y con estrategia<br/>
        <span class="text-[--color-muted]">+ Tecnología Open Source</span><br/>
        <span class="text-[--color-muted]">+ Agentes de IA que trabajan por ti</span>
      </h1>
      <div class="mt-8 w-12 h-px bg-[--color-ink]"></div>
    </div>
    <!-- Scroll arrow -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 scroll-arrow z-10">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="text-[--color-muted]">
        <path d="M12 5L12 19M12 19L5 12M12 19L19 12" />
      </svg>
    </div>
  </section>

  <script is:inline>
    (function() {
      var c = document.getElementById('sketch-bg');
      if (!c) return;
      var ctx = c.getContext('2d');
      var pts = [];
      var W, H, mx = -1, my = -1, t = 0;

      function sz() {
        W = c.parentElement.offsetWidth;
        H = c.parentElement.offsetHeight;
        c.width = W;
        c.height = H;
      }
      sz();

      function rnd(a, b) { return Math.random() * (b - a) + a; }
      function noise(v) { return (Math.sin(v * 127.1 + Math.cos(v * 311.7) * 43758.5) * 0.5 + 0.5); }

      for (var i = 0; i < 80; i++) {
        pts.push({ x: rnd(0, W), y: rnd(0, H), vx: rnd(-0.3, 0.3), vy: rnd(-0.3, 0.3), r: rnd(2, 5), n: rnd(0, 1000) });
      }

      c.parentElement.addEventListener('mousemove', function(e) {
        var r = c.getBoundingClientRect();
        mx = e.clientX - r.left;
        my = e.clientY - r.top;
      });

      function draw() {
        ctx.clearRect(0, 0, W, H);
        t += 0.003;

        for (var i = 0; i < pts.length; i++) {
          var a = pts[i];
          var ang = noise(a.n + t) * Math.PI * 4;
          a.x += Math.cos(ang) * 0.4 + a.vx * 0.1;
          a.y += Math.sin(ang) * 0.4 + a.vy * 0.1;

          if (mx > 0 && my > 0) {
            var dx = mx - a.x, dy = my - a.y;
            var d = Math.sqrt(dx * dx + dy * dy);
            if (d < 300) { var force = (1 - d / 300) * 0.08; a.x -= dx * force; a.y -= dy * force; }
          }

          if (a.x < -20) a.x = W + 20;
          if (a.x > W + 20) a.x = -20;
          if (a.y < -20) a.y = H + 20;
          if (a.y > H + 20) a.y = -20;

          ctx.strokeStyle = 'rgba(10,10,8,0.4)';
          ctx.lineWidth = 0.8;
          ctx.beginPath();
          ctx.arc(a.x, a.y, a.r, 0, Math.PI * 2);
          ctx.stroke();

          for (var j = i + 1; j < pts.length; j++) {
            var b = pts[j];
            var dd = Math.hypot(a.x - b.x, a.y - b.y);
            if (dd < 130) {
              var al = Math.max(0, (1 - dd / 130) * 0.18);
              ctx.strokeStyle = 'rgba(10,10,8,' + al + ')';
              ctx.lineWidth = 0.5;
              ctx.beginPath();
              ctx.moveTo(a.x, a.y);
              ctx.lineTo(b.x, b.y);
              ctx.stroke();
            }
          }
        }
        requestAnimationFrame(draw);
      }
      draw();
      window.addEventListener('resize', sz);
    })();
  </script>

  <!-- Filosofía -->
  <section class="px-6 md:px-12 py-24 md:py-40">
    <div class="grid md:grid-cols-12 gap-8 md:gap-16">
      <div class="md:col-span-4 md:col-start-2">
        <p class="text-xs tracking-[0.3em] uppercase text-[--color-muted] mb-6">Filosofía</p>
      </div>
      <div class="md:col-span-5">
        <p class="text-xl md:text-2xl font-light leading-relaxed">
          Combinamos la sensibilidad estética del diseño de autor con herramientas open source 
          para crear sistemas visuales que son tan bellos como soberanos.
        </p>
        <p class="mt-6 text-sm text-[--color-muted] leading-relaxed max-w-prose">
          Cada proyecto parte de una investigación profunda del contexto, el desarrollo de una estrategia y una dirección artística clara, ejecutada con tecnología limpia y respetando estrictamente que tus datos te pertenezcan.
        </p>
      </div>
    </div>
  </section>

  <!-- Servicios -->
  <section class="px-6 md:px-12 py-24 md:py-40 border-t border-[--color-border]">
    <div class="grid md:grid-cols-12 gap-8 md:gap-16">
      <div class="md:col-span-4 md:col-start-2">
        <p class="text-xs tracking-[0.3em] uppercase text-[--color-muted] mb-6">Servicios</p>
      </div>
      <div class="md:col-span-6">
        <div class="stagger">
          {[
            { title: 'Dirección de arte', desc: 'Desarrollo y dirección creativa para marcas y proyectos culturales.' },
            { title: 'Fotografía', desc: 'Fotografía editorial de retrato y arquitectónica con mirada de autor.' },
            { title: 'Diseño web y Desarrollo de Apps', desc: 'Sitios funcionales, rápidos, accesibles y aplicaciones a la medida de tus necesidades, limpias y con tu marca.' },
            { title: 'Automatización creativa', desc: 'Flujos de trabajo con IA y herramientas open source para que tu proyecto escale sin perder control ni calidad.' },
          ].map((s, i) => (
            <div class="py-8 border-b border-[--color-border] group">
              <div class="flex items-start justify-between">
                <div>
                  <h3 class="text-lg font-medium">{s.title}</h3>
                  <p class="mt-2 text-sm text-[--color-muted] max-w-md">{s.desc}</p>
                </div>
                <span class="text-xs text-[--color-muted] font-light mt-1">0{i + 1}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Francisco -->
  <section class="px-6 md:px-12 py-24 md:py-40 border-t border-[--color-border]">
    <div class="grid md:grid-cols-12 gap-8 md:gap-16">
      <div class="md:col-span-4 md:col-start-2">
        <p class="text-xs tracking-[0.3em] uppercase text-[--color-muted] mb-6">Sobre</p>
      </div>
      <div class="md:col-span-5">
        <h2 class="text-3xl md:text-4xl font-light leading-tight">Francisco León</h2>
        <p class="mt-1 text-sm text-[--color-muted]">Director de Arte & Fotógrafo</p>
        <p class="mt-8 text-base leading-relaxed text-[--color-muted]">
          Desde Oaxaca dirijo <span class="font-medium text-[--color-ink]">ioon</span>, un estudio donde el diseño es pensamiento 
          y la tecnología es herramienta — nunca al revés. Cada proyecto es una 
          pieza de autor con la solidez de la ingeniería open source.
        </p>
      </div>
    </div>
  </section>

  <!-- Contacto -->
  <section id="contacto" class="px-6 md:px-12 py-24 md:py-40 border-t border-[--color-border]">
    <div class="grid md:grid-cols-12 gap-8 md:gap-16">
      <div class="md:col-span-4 md:col-start-2">
        <p class="text-xs tracking-[0.3em] uppercase text-[--color-muted] mb-6">Contacto</p>
      </div>
      <div class="md:col-span-5">
        <a href="mailto:hola.ioon@gmail.com" class="text-2xl md:text-3xl font-light hover:text-[--color-muted] transition-colors">
          hola.ioon@gmail.com
        </a>
        <div class="mt-8 flex gap-8 text-sm text-[--color-muted]">
          <a href="tel:+529515081629" class="hover:text-[--color-ink] transition-colors">+52 951 5081629</a>
          <span>Oaxaca, MX</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="px-6 md:px-12 py-8 border-t border-[--color-border]">
    <div class="flex items-center justify-between text-xs text-[--color-muted]">
      <span>&copy; {new Date().getFullYear()} ioon</span>
      <span class="tracking-[0.2em] uppercase">Diseño para la gente</span>
    </div>
  </footer>
</Base>
