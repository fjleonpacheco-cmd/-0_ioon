---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

// Get presentation count for the nav hint
const decks = import.meta.glob('../content/presentaciones/*/config.json', { eager: true });
const deckCount = Object.keys(decks).length;
---
<Base>
  <!-- Nav -->
  <nav class="fixed top-0 left-0 w-full z-50 bg-[--color-paper]/90 backdrop-blur-sm">
    <div class="flex items-center justify-between px-6 md:px-12 py-5">
      <a href="/"><img src="/logo.png" alt="ioon" class="h-5" /></a>
      <a href="#contacto" class="text-[--color-muted] text-xs tracking-[0.2em] uppercase hover:text-[--color-ink] transition-colors">Contacto</a>
    </div>
  </nav>

  <!-- Hero -->
  <section class="h-screen flex flex-col justify-end px-6 md:px-12 pb-24 md:pb-32 relative overflow-hidden">
    <!-- P5.js organic particles -->
    <div id="sketch-bg" class="absolute inset-0 z-0"></div>

    <div class="stagger relative z-10">
      <img src="/logo.png" alt="ioon" class="w-[150px] mb-10" />
      <p class="text-[--color-muted] text-xs tracking-[0.3em] uppercase mb-4">Estudio de innovación — Oaxaca, México</p>
      <h1 class="text-[clamp(2.5rem,8vw,7rem)] font-light leading-[0.9] tracking-tight max-w-[20ch]">
        Diseño limpio<br/>y con estrategia<br/>
        <span class="text-[--color-muted]">+ Tecnología Open Source</span><br/>
        <span class="text-[--color-muted]">+ Automatizaciones</span>
      </h1>
      <div class="mt-8 w-12 h-px bg-[--color-ink]"></div>
    </div>
    <!-- Scroll arrow -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 scroll-arrow z-10">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="text-[--color-muted]">
        <path d="M12 5L12 19M12 19L5 12M12 19L19 12" />
      </svg>
    </div>
  </section>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.4/p5.min.js"></script>
  <script>
    new p5((p) => {
      const particles = [];
      const count = 80;
      let w, h;

      p.setup = () => {
        const container = document.getElementById('sketch-bg');
        w = container.offsetWidth;
        h = container.offsetHeight;
        const canvas = p.createCanvas(w, h);
        canvas.parent(container);
        p.noFill();

        for (let i = 0; i < count; i++) {
          particles.push({
            x: p.random(w),
            y: p.random(h),
            vx: p.random(-0.3, 0.3),
            vy: p.random(-0.3, 0.3),
            r: p.random(1, 3),
            noiseOff: p.random(1000),
          });
        }
      };

      p.draw = () => {
        p.clear();
        const t = p.frameCount * 0.003;

        for (let i = 0; i < particles.length; i++) {
          const a = particles[i];
          // Organic noise-driven movement
          const angle = p.noise(a.noiseOff + t) * p.TWO_PI * 2;
          a.x += Math.cos(angle) * 0.4 + a.vx;
          a.y += Math.sin(angle) * 0.4 + a.vy;

          // Subtle mouse influence
          if (p.mouseX > 0 && p.mouseY > 0) {
            const dx = p.mouseX - a.x;
            const dy = p.mouseY - a.y;
            const dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < 200) {
              a.x -= dx * 0.002;
              a.y -= dy * 0.002;
            }
          }

          // Wrap edges
          if (a.x < -20) a.x = w + 20;
          if (a.x > w + 20) a.x = -20;
          if (a.y < -20) a.y = h + 20;
          if (a.y > h + 20) a.y = -20;

          // Draw particle
          p.stroke(10, 10, 8, 25);
          p.strokeWeight(a.r);
          p.point(a.x, a.y);

          // Connect nearby particles
          for (let j = i + 1; j < particles.length; j++) {
            const b = particles[j];
            const d = p.dist(a.x, a.y, b.x, b.y);
            if (d < 120) {
              const alpha = p.map(d, 0, 120, 18, 0);
              p.stroke(10, 10, 8, alpha);
              p.strokeWeight(0.5);
              p.line(a.x, a.y, b.x, b.y);
            }
          }
        }
      };

      p.windowResized = () => {
        const container = document.getElementById('sketch-bg');
        w = container.offsetWidth;
        h = container.offsetHeight;
        p.resizeCanvas(w, h);
      };
    }, document.getElementById('sketch-bg'));
  </script>

  <!-- Filosofía -->
  <section class="px-6 md:px-12 py-24 md:py-40">
    <div class="grid md:grid-cols-12 gap-8 md:gap-16">
      <div class="md:col-span-4 md:col-start-2">
        <p class="text-xs tracking-[0.3em] uppercase text-[--color-muted] mb-6">Filosofía</p>
      </div>
      <div class="md:col-span-5">
        <p class="text-xl md:text-2xl font-light leading-relaxed">
          Combinamos la sensibilidad estética del diseño de autor con herramientas open source 
          para crear sistemas visuales que son tan bellos como soberanos.
        </p>
        <p class="mt-6 text-sm text-[--color-muted] leading-relaxed max-w-prose">
          Cada proyecto parte de una dirección artística clara, ejecutada con tecnología 
          que te pertenece. Sin dependencias innecesarias, sin cajas negras.
        </p>
      </div>
    </div>
  </section>

  <!-- Servicios -->
  <section class="px-6 md:px-12 py-24 md:py-40 border-t border-[--color-border]">
    <div class="grid md:grid-cols-12 gap-8 md:gap-16">
      <div class="md:col-span-4 md:col-start-2">
        <p class="text-xs tracking-[0.3em] uppercase text-[--color-muted] mb-6">Servicios</p>
      </div>
      <div class="md:col-span-6">
        <div class="stagger">
          {[
            { title: 'Dirección de arte', desc: 'Identidad visual, branding, dirección creativa para marcas y proyectos culturales.' },
            { title: 'Fotografía', desc: 'Fotografía editorial, de producto y arquitectónica con mirada de autor.' },
            { title: 'Diseño web', desc: 'Sitios estáticos, rápidos, accesibles. Desplegados en tu propia infraestructura.' },
            { title: 'Automatización creativa', desc: 'Flujos de trabajo con IA y herramientas open source para escalar sin perder calidad.' },
          ].map((s, i) => (
            <div class="py-8 border-b border-[--color-border] group">
              <div class="flex items-start justify-between">
                <div>
                  <h3 class="text-lg font-medium">{s.title}</h3>
                  <p class="mt-2 text-sm text-[--color-muted] max-w-md">{s.desc}</p>
                </div>
                <span class="text-xs text-[--color-muted] font-light mt-1">0{i + 1}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Francisco -->
  <section class="px-6 md:px-12 py-24 md:py-40 border-t border-[--color-border]">
    <div class="grid md:grid-cols-12 gap-8 md:gap-16">
      <div class="md:col-span-4 md:col-start-2">
        <p class="text-xs tracking-[0.3em] uppercase text-[--color-muted] mb-6">Sobre</p>
      </div>
      <div class="md:col-span-5">
        <h2 class="text-3xl md:text-4xl font-light leading-tight">Francisco León</h2>
        <p class="mt-1 text-sm text-[--color-muted]">Director de Arte & Fotógrafo</p>
        <p class="mt-8 text-base leading-relaxed text-[--color-muted]">
          Desde Oaxaca dirijo ioon, un estudio donde el diseño es pensamiento 
          y la tecnología es herramienta — nunca al revés. Cada proyecto es una 
          pieza de autor con la solidez de la ingeniería open source.
        </p>
      </div>
    </div>
  </section>

  <!-- Contacto -->
  <section id="contacto" class="px-6 md:px-12 py-24 md:py-40 border-t border-[--color-border]">
    <div class="grid md:grid-cols-12 gap-8 md:gap-16">
      <div class="md:col-span-4 md:col-start-2">
        <p class="text-xs tracking-[0.3em] uppercase text-[--color-muted] mb-6">Contacto</p>
      </div>
      <div class="md:col-span-5">
        <a href="mailto:hola@ioon.mx" class="text-2xl md:text-3xl font-light hover:text-[--color-muted] transition-colors">
          hola@ioon.mx
        </a>
        <div class="mt-8 flex gap-8 text-sm text-[--color-muted]">
          <a href="https://instagram.com/ioon.mx" target="_blank" rel="noopener" class="hover:text-[--color-ink] transition-colors">Instagram</a>
          <span>Oaxaca, MX</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="px-6 md:px-12 py-8 border-t border-[--color-border]">
    <div class="flex items-center justify-between text-xs text-[--color-muted]">
      <span>&copy; {new Date().getFullYear()} ioon</span>
      <span class="tracking-[0.2em] uppercase">Diseño de Autor</span>
    </div>
  </footer>
</Base>
